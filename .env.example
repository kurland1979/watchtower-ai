# ============================================================
# WatchTower AI — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git — only .env.example
# ============================================================

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Slack ---
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_CHANNEL_ID=C0YOUR-CHANNEL-ID

# --- Scheduler ---
RUN_HOUR=8
RUN_MINUTE=0

# --- Dashboard API ---
WATCHTOWER_API_KEY=your-secure-dashboard-api-key
FLASK_DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# --- Scraper ---
SCRAPER_TIMEOUT=10
SCRAPER_MAX_RETRIES=3
OVERALL_JOB_TIMEOUT=3600

# --- LLM ---
LLM_CHAR_BUDGET=3000
LLM_CHAR_BUDGET_FIRST_SCAN=5000

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=text
